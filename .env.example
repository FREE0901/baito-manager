# セッションシークレット（必須・ランダムな長い文字列を設定してください）
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ここにランダムな文字列を入力

# 環境設定
NODE_ENV=production

# 初期管理者パスワード（初回デプロイ時のみ使用。ログイン後すぐに変更してください）
ADMIN_INITIAL_PASSWORD=ここに初期パスワードを設定

# ポート（Railway等は自動設定されるため通常不要）
# PORT=3000
