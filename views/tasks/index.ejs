<%- include('../layout') %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">業務管理</h1>
</div>

<!-- 新規業務作成フォーム -->
<div class="bg-white rounded-xl shadow p-6 mb-6">
  <h2 class="text-lg font-bold text-gray-700 mb-4">新規業務登録</h2>
  <form action="/tasks" method="POST">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">担当者</label>
        <select name="employee_id" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="">全員</option>
          <% employees.forEach(emp => { %>
            <option value="<%= emp.id %>"><%= emp.name %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">タイトル <span class="text-red-500">*</span></label>
        <input type="text" name="title" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">期限日</label>
        <input type="date" name="due_date" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-gray-600 mb-1">説明</label>
        <textarea name="description" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-600 mb-1">優先度</label>
        <select name="priority" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
          <option value="low">低</option>
          <option value="normal" selected>通常</option>
          <option value="high">高</option>
        </select>
      </div>
    </div>
    <div class="mt-4">
      <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-lg text-sm hover:bg-indigo-700">登録</button>
    </div>
  </form>
</div>

<!-- ステータスフィルター -->
<div class="flex gap-2 mb-4 flex-wrap">
  <a href="/tasks" class="px-4 py-2 rounded-lg text-sm font-medium <%= currentStatus === '' ? 'bg-indigo-600 text-white' : 'bg-white text-gray-600 border border-gray-300 hover:bg-gray-50' %>">全て</a>
  <a href="/tasks?status=pending" class="px-4 py-2 rounded-lg text-sm font-medium <%= currentStatus === 'pending' ? 'bg-yellow-500 text-white' : 'bg-white text-gray-600 border border-gray-300 hover:bg-gray-50' %>">未着手</a>
  <a href="/tasks?status=in_progress" class="px-4 py-2 rounded-lg text-sm font-medium <%= currentStatus === 'in_progress' ? 'bg-blue-500 text-white' : 'bg-white text-gray-600 border border-gray-300 hover:bg-gray-50' %>">進行中</a>
  <a href="/tasks?status=completed" class="px-4 py-2 rounded-lg text-sm font-medium <%= currentStatus === 'completed' ? 'bg-green-500 text-white' : 'bg-white text-gray-600 border border-gray-300 hover:bg-gray-50' %>">完了</a>
</div>

<!-- 業務一覧 -->
<div class="bg-white rounded-xl shadow overflow-hidden">
  <% if (tasks.length === 0) { %>
    <div class="px-6 py-12 text-center text-gray-400">業務が登録されていません</div>
  <% } else { %>
    <div class="divide-y">
      <% tasks.forEach(task => { %>
        <div class="px-6 py-4 flex flex-col md:flex-row md:items-center gap-3">
          <!-- 優先度バッジ + タイトル -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <% if (task.priority === 'high') { %>
                <span class="bg-red-100 text-red-700 px-2 py-0.5 rounded text-xs font-medium">高</span>
              <% } else if (task.priority === 'normal') { %>
                <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs font-medium">通常</span>
              <% } else { %>
                <span class="bg-gray-100 text-gray-500 px-2 py-0.5 rounded text-xs font-medium">低</span>
              <% } %>
              <span class="font-medium text-gray-800 truncate"><%= task.title %></span>
            </div>
            <% if (task.description) { %>
              <div class="text-xs text-gray-500 max-w-xl">
                <p class="desc-short-<%= task.id %> whitespace-pre-wrap line-clamp-2"><%= task.description %></p>
                <% if (task.description.length > 80) { %>
                  <button type="button" onclick="toggleDesc(<%= task.id %>)"
                    class="text-indigo-500 hover:underline mt-0.5" id="desc-btn-<%= task.id %>">もっと見る</button>
                <% } %>
              </div>
            <% } %>
          </div>

          <!-- 担当者 -->
          <div class="text-sm text-gray-600 md:w-24 shrink-0">
            <%= task.employee_name || '全員' %>
          </div>

          <!-- 期限日 -->
          <div class="text-sm text-gray-500 md:w-36 shrink-0">
            <% if (task.due_date) { %>
              <span class="<%= (task.status !== 'completed' && task.due_date < new Date().toISOString().split('T')[0]) ? 'text-red-500 font-medium' : '' %>"><%= task.due_date %></span>
              <% if (task.carried_count > 0) { %>
                <span class="bg-purple-100 text-purple-700 text-xs px-1.5 py-0.5 rounded ml-1">持越<%= task.carried_count %>回</span>
              <% } %>
            <% } else { %>
              <span class="text-gray-300">期限なし</span>
            <% } %>
          </div>

          <!-- ステータスバッジ -->
          <div class="md:w-20 shrink-0">
            <% if (task.status === 'pending') { %>
              <span class="bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded text-xs font-medium">未着手</span>
            <% } else if (task.status === 'in_progress') { %>
              <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded text-xs font-medium">進行中</span>
            <% } else { %>
              <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded text-xs font-medium">完了</span>
            <% } %>
          </div>

          <!-- アクションボタン -->
          <div class="flex items-center gap-2 shrink-0 flex-wrap">
            <% if (task.status === 'pending') { %>
              <form action="/tasks/<%= task.id %>/update" method="POST" class="inline">
                <input type="hidden" name="status" value="in_progress">
                <button type="submit" class="text-blue-600 hover:text-blue-800 text-xs border border-blue-300 rounded px-2 py-1 hover:bg-blue-50">着手</button>
              </form>
            <% } %>
            <% if (task.status === 'in_progress') { %>
              <form action="/tasks/<%= task.id %>/update" method="POST" class="inline">
                <input type="hidden" name="status" value="completed">
                <button type="submit" class="text-green-600 hover:text-green-800 text-xs border border-green-300 rounded px-2 py-1 hover:bg-green-50">完了</button>
              </form>
            <% } %>
            <% if (task.status === 'completed') { %>
              <form action="/tasks/<%= task.id %>/update" method="POST" class="inline">
                <input type="hidden" name="status" value="pending">
                <button type="submit" class="text-yellow-600 hover:text-yellow-800 text-xs border border-yellow-300 rounded px-2 py-1 hover:bg-yellow-50">戻す</button>
              </form>
            <% } %>
            <% if (task.status !== 'completed' && task.due_date) { %>
              <form action="/tasks/<%= task.id %>/carry-over" method="POST" class="inline flex items-center gap-1">
                <input type="date" name="new_due_date" class="text-xs border rounded px-1 py-0.5 w-28">
                <button type="submit" class="text-purple-600 hover:text-purple-800 text-xs border border-purple-300 rounded px-2 py-1 hover:bg-purple-50">持越</button>
              </form>
            <% } %>
            <form action="/tasks/<%= task.id %>/delete" method="POST" class="inline" onsubmit="return confirm('この業務を削除しますか？')">
              <button type="submit" class="text-red-500 hover:text-red-700 text-xs border border-red-300 rounded px-2 py-1 hover:bg-red-50">削除</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<script>
function toggleDesc(id) {
  const p = document.querySelector('.desc-short-' + id);
  const btn = document.getElementById('desc-btn-' + id);
  if (p.classList.contains('line-clamp-2')) {
    p.classList.remove('line-clamp-2');
    btn.textContent = '閉じる';
  } else {
    p.classList.add('line-clamp-2');
    btn.textContent = 'もっと見る';
  }
}
</script>

<%- include('../footer') %>
