<%- include('layout') %>

<h1 class="text-2xl font-bold text-gray-800 mb-6">シフト希望提出</h1>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- 提出フォーム -->
  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-bold text-gray-700 mb-4">新しい希望を出す</h2>
    <form method="POST" action="/my/shift-request">
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">日付</label>
          <input type="date" name="date" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">開始時刻</label>
            <input type="time" name="start_time" required value="09:00" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">終了時刻</label>
            <input type="time" name="end_time" required value="17:00" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">備考</label>
          <input type="text" name="note" placeholder="例: 午前中のみ希望" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <button type="submit" class="w-full bg-green-600 text-white py-2 rounded-lg hover:bg-green-700 text-sm">提出する</button>
      </div>
    </form>
  </div>

  <!-- 提出済み一覧 -->
  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-bold text-gray-700 mb-4">提出済みの希望</h2>
    <% if (requests.length === 0) { %>
      <p class="text-gray-400 text-sm">提出された希望はありません</p>
    <% } else { %>
      <ul class="space-y-3">
        <% requests.forEach(r => { %>
          <li class="border rounded-lg p-3">
            <div class="flex justify-between items-start">
              <div>
                <div class="font-medium text-sm"><%= r.date %></div>
                <div class="text-sm text-gray-500"><%= r.start_time %> - <%= r.end_time %></div>
                <% if (r.note) { %><div class="text-xs text-gray-400 mt-1"><%= r.note %></div><% } %>
                <% if (r.admin_note) { %><div class="text-xs text-indigo-500 mt-1">管理者メモ: <%= r.admin_note %></div><% } %>
              </div>
              <div>
                <% if (r.status === 'pending') { %>
                  <span class="bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded text-xs">承認待ち</span>
                  <form method="POST" action="/my/shift-request/<%= r.id %>/cancel" class="mt-1">
                    <button type="submit" class="text-red-400 hover:text-red-600 text-xs">取消</button>
                  </form>
                <% } else if (r.status === 'approved') { %>
                  <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded text-xs">承認済み</span>
                <% } else { %>
                  <span class="bg-red-100 text-red-700 px-2 py-0.5 rounded text-xs">却下</span>
                <% } %>
              </div>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</div>

<%- include('footer') %>
