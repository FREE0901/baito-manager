<%- include('layout') %>

<h1 class="text-2xl font-bold text-gray-800 mb-6">有給休暇</h1>

<div class="bg-white rounded-xl shadow p-4 mb-6 text-center">
  <span class="text-gray-500 text-sm">残り </span>
  <span class="text-2xl font-bold text-purple-600"><%= remaining %></span>
  <span class="text-gray-500 text-sm"> 日（付与 <%= employee.paid_leave_days || 0 %> 日）</span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-bold text-gray-700 mb-4">有給を申請する</h2>
    <form method="POST" action="/my/leave">
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">日付</label>
          <input type="date" name="date" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">理由（任意）</label>
          <input type="text" name="reason" placeholder="例: 通院のため" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <button type="submit" class="w-full bg-purple-600 text-white py-2 rounded-lg hover:bg-purple-700 text-sm">申請する</button>
      </div>
    </form>
  </div>

  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-bold text-gray-700 mb-4">申請履歴</h2>
    <% if (leaves.length === 0) { %>
      <p class="text-gray-400 text-sm">申請はありません</p>
    <% } else { %>
      <ul class="space-y-3">
        <% leaves.forEach(l => { %>
          <li class="border rounded-lg p-3">
            <div class="flex justify-between items-start">
              <div>
                <div class="font-medium text-sm"><%= l.date %></div>
                <% if (l.reason) { %><div class="text-xs text-gray-400 mt-1"><%= l.reason %></div><% } %>
                <% if (l.admin_note) { %><div class="text-xs text-indigo-500 mt-1">管理者: <%= l.admin_note %></div><% } %>
              </div>
              <div>
                <% if (l.status === 'pending') { %>
                  <span class="bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded text-xs">承認待ち</span>
                  <form method="POST" action="/my/leave/<%= l.id %>/cancel" class="mt-1">
                    <button type="submit" class="text-red-400 hover:text-red-600 text-xs">取消</button>
                  </form>
                <% } else if (l.status === 'approved') { %>
                  <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded text-xs">承認済み</span>
                <% } else { %>
                  <span class="bg-red-100 text-red-700 px-2 py-0.5 rounded text-xs">却下</span>
                <% } %>
              </div>
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</div>

<%- include('footer') %>
