<%- include('layout') %>

<h1 class="text-2xl font-bold text-gray-800 mb-2">こんにちは、<%= employee.name %>さん</h1>
<p class="text-gray-500 text-sm mb-6">時給: <%= employee.hourly_wage.toLocaleString() %>円</p>

<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <div class="bg-white rounded-xl shadow p-4 text-center">
    <div class="text-xs text-gray-500">今月の勤務</div>
    <div class="text-2xl font-bold text-green-600"><%= monthAttendance.days || 0 %><span class="text-sm font-normal text-gray-500"> 日</span></div>
  </div>
  <div class="bg-white rounded-xl shadow p-4 text-center">
    <div class="text-xs text-gray-500">労働時間</div>
    <div class="text-2xl font-bold text-blue-600"><%= (monthAttendance.hours || 0).toFixed(1) %><span class="text-sm font-normal text-gray-500"> h</span></div>
  </div>
  <div class="bg-white rounded-xl shadow p-4 text-center">
    <div class="text-xs text-gray-500">未承認希望</div>
    <div class="text-2xl font-bold text-orange-600"><%= pendingRequests.length %><span class="text-sm font-normal text-gray-500"> 件</span></div>
  </div>
  <div class="bg-white rounded-xl shadow p-4 text-center">
    <div class="text-xs text-gray-500">有給残日数</div>
    <div class="text-2xl font-bold text-purple-600"><%= leaveRemaining %><span class="text-sm font-normal text-gray-500"> 日</span></div>
  </div>
</div>

<!-- 打刻ボタン -->
<div class="bg-white rounded-xl shadow p-5 mb-6">
  <h2 class="font-bold text-gray-700 mb-3">打刻（<%= today %>）</h2>
  <% if (todayAttendance && todayAttendance.clock_in && todayAttendance.clock_out) { %>
    <p class="text-green-600 font-medium">出勤 <%= todayAttendance.clock_in %> ／ 退勤 <%= todayAttendance.clock_out %></p>
    <p class="text-gray-400 text-xs mt-1">本日の打刻は完了しています</p>
  <% } else if (todayAttendance && todayAttendance.clock_in) { %>
    <p class="text-blue-600 font-medium mb-3">出勤済み: <%= todayAttendance.clock_in %></p>
    <form method="POST" action="/my/clock-out" class="flex flex-wrap items-end gap-3">
      <div>
        <label class="text-xs text-gray-600">区分</label>
        <select name="work_type" class="border rounded px-2 py-1 text-sm">
          <option value="office" <%= todayAttendance.work_type === 'office' ? 'selected' : '' %>>出社</option>
          <option value="remote" <%= todayAttendance.work_type === 'remote' ? 'selected' : '' %>>リモート</option>
        </select>
      </div>
      <div>
        <label class="text-xs text-gray-600">休憩（分）</label>
        <input type="number" name="break_minutes" value="60" min="0" class="w-20 border rounded px-2 py-1 text-sm">
      </div>
      <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded-lg text-sm hover:bg-red-700">退勤</button>
    </form>
  <% } else { %>
    <form method="POST" action="/my/clock-in" class="flex flex-wrap items-end gap-3">
      <div>
        <label class="text-xs text-gray-600">区分</label>
        <select name="work_type" class="border rounded px-2 py-1 text-sm">
          <option value="office">出社</option>
          <option value="remote">リモート</option>
        </select>
      </div>
      <button type="submit" class="bg-green-600 text-white px-6 py-2 rounded-lg text-sm hover:bg-green-700">出勤</button>
    </form>
  <% } %>
</div>

<!-- お知らせ -->
<% if (announcements.length > 0) { %>
<div class="bg-white rounded-xl shadow p-5 mb-6">
  <h2 class="font-bold text-gray-700 mb-3">お知らせ</h2>
  <ul class="space-y-2">
    <% announcements.forEach(a => { %>
      <li class="border-b pb-2">
        <div class="flex justify-between items-start">
          <span class="font-medium text-sm"><%= a.title %></span>
          <span class="text-xs text-gray-400"><%= a.created_at %></span>
        </div>
        <% if (a.content) { %><p class="text-sm text-gray-600 mt-1" style="white-space: pre-wrap;"><%= a.content %></p><% } %>
      </li>
    <% }) %>
  </ul>
</div>
<% } %>

<!-- 今日のシフト -->
<div class="bg-white rounded-xl shadow p-5 mb-6">
  <h2 class="font-bold text-gray-700 mb-3">今日のシフト（<%= today %>）</h2>
  <% if (todayShift) { %>
    <div class="text-lg font-medium text-green-700"><%= todayShift.start_time %> - <%= todayShift.end_time %></div>
    <% if (todayShift.note) { %><p class="text-sm text-gray-500 mt-1"><%= todayShift.note %></p><% } %>
  <% } else { %>
    <p class="text-gray-400 text-sm">今日のシフトはありません</p>
  <% } %>
</div>

<!-- 担当タスク -->
<% if (myTasks.length > 0) { %>
<div class="bg-white rounded-xl shadow p-5 mb-6">
  <h2 class="font-bold text-gray-700 mb-3">担当業務</h2>
  <ul class="space-y-2">
    <% myTasks.forEach(t => { %>
      <li class="flex justify-between items-center py-2 border-b">
        <div>
          <% if (t.priority === 'high') { %><span class="bg-red-100 text-red-700 text-xs px-1.5 py-0.5 rounded mr-1">高</span><% } %>
          <span class="text-sm font-medium"><%= t.title %></span>
          <% if (t.due_date) { %><span class="text-xs text-gray-400 ml-2">〆 <%= t.due_date %></span><% } %>
        </div>
        <div class="flex gap-1">
          <% if (t.status === 'pending') { %>
            <form method="POST" action="/my/tasks/<%= t.id %>/update"><input type="hidden" name="status" value="in_progress"><button class="bg-blue-500 text-white px-2 py-0.5 rounded text-xs">着手</button></form>
          <% } else if (t.status === 'in_progress') { %>
            <form method="POST" action="/my/tasks/<%= t.id %>/update"><input type="hidden" name="status" value="completed"><button class="bg-green-500 text-white px-2 py-0.5 rounded text-xs">完了</button></form>
          <% } else { %>
            <span class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded">完了</span>
          <% } %>
        </div>
      </li>
    <% }) %>
  </ul>
  <a href="/my/tasks" class="text-green-600 hover:underline text-sm mt-2 inline-block">すべて見る →</a>
</div>
<% } %>

<!-- 今後のシフト（カレンダー） -->
<%
const calNow = new Date();
const calYear = calNow.getFullYear();
const calMonth = calNow.getMonth(); // 0-indexed
const calTodayStr = today;
const monthNames = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
const dayNames = ['日','月','火','水','木','金','土'];
const firstWeekDay = new Date(calYear, calMonth, 1).getDay();
const daysInCalMonth = new Date(calYear, calMonth + 1, 0).getDate();
// shiftMap: 'YYYY-MM-DD' → shift
const shiftMap = {};
calendarShifts.forEach(s => { shiftMap[s.date] = s; });
%>
<div class="bg-white rounded-xl shadow p-5 mb-6">
  <h2 class="font-bold text-gray-700 mb-3">今後のシフト（<%= calYear %>年 <%= monthNames[calMonth] %>）</h2>
  <div class="grid grid-cols-7 gap-1 text-center text-xs mb-1">
    <% dayNames.forEach((d, i) => { %>
      <div class="font-bold <%= i===0 ? 'text-red-500' : i===6 ? 'text-blue-500' : 'text-gray-500' %>"><%= d %></div>
    <% }) %>
  </div>
  <div class="grid grid-cols-7 gap-1 text-center text-xs">
    <%
    // 1日前の空白セル
    for (let i = 0; i < firstWeekDay; i++) { %>
      <div></div>
    <% } %>
    <% for (let d = 1; d <= daysInCalMonth; d++) {
      const dateStr = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const shift = shiftMap[dateStr];
      const isToday = dateStr === calTodayStr;
      const dow = (firstWeekDay + d - 1) % 7;
      const isPast = dateStr < calTodayStr;
    %>
      <div class="rounded-lg py-1 px-0.5 min-h-[52px] flex flex-col items-center justify-start
        <%= isToday ? 'bg-green-100 ring-2 ring-green-400' : shift ? 'bg-indigo-50' : '' %>
        <%= isPast && !isToday ? 'opacity-40' : '' %>">
        <span class="font-medium leading-tight
          <%= isToday ? 'text-green-700' : dow===0 ? 'text-red-500' : dow===6 ? 'text-blue-500' : 'text-gray-700' %>">
          <%= d %>
        </span>
        <% if (shift) { %>
          <span class="text-indigo-700 font-bold leading-tight mt-0.5" style="font-size:0.6rem;"><%= shift.start_time.slice(0,5) %></span>
          <span class="text-indigo-500 leading-tight" style="font-size:0.6rem;">〜<%= shift.end_time.slice(0,5) %></span>
        <% } %>
      </div>
    <% } %>
  </div>
  <% if (Object.keys(shiftMap).length === 0) { %>
    <p class="text-gray-400 text-sm mt-3 text-center">今月のシフトはまだ登録されていません</p>
  <% } %>
</div>

<div class="flex flex-wrap gap-3">
  <a href="/my/shift-request" class="bg-green-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-green-700">シフト希望を出す</a>
  <a href="/my/attendance" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-blue-700">出退勤を確認</a>
  <a href="/my/report" class="bg-purple-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-purple-700">業務報告</a>
  <a href="/my/payroll" class="bg-yellow-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-yellow-700">給与明細</a>
  <a href="/my/profile" class="bg-gray-500 text-white px-4 py-2 rounded-lg text-sm hover:bg-gray-600">プロフィール編集</a>
</div>

<%- include('footer') %>
