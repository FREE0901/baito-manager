<%- include('../layout') %>

<h1 class="text-2xl font-bold text-gray-800 mb-4">シフト管理</h1>

<!-- 月切り替え -->
<div class="flex items-center gap-4 mb-6">
  <a href="/shifts?year=<%= month === 1 ? year - 1 : year %>&month=<%= month === 1 ? 12 : month - 1 %>"
    class="bg-gray-200 px-3 py-1 rounded hover:bg-gray-300">&laquo; 前月</a>
  <span class="text-lg font-bold"><%= year %>年<%= month %>月</span>
  <a href="/shifts?year=<%= month === 12 ? year + 1 : year %>&month=<%= month === 12 ? 1 : month + 1 %>"
    class="bg-gray-200 px-3 py-1 rounded hover:bg-gray-300">翌月 &raquo;</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- カレンダー -->
  <div class="lg:col-span-2 bg-white rounded-xl shadow p-4 overflow-x-auto">
    <div class="grid grid-cols-7 gap-px bg-gray-200 min-w-[600px]">
      <% ['日','月','火','水','木','金','土'].forEach((d, i) => { %>
        <div class="bg-gray-50 text-center py-1 text-xs font-bold <%= i === 0 ? 'text-red-500' : i === 6 ? 'text-blue-500' : 'text-gray-600' %>"><%= d %></div>
      <% }) %>
      <% for (let i = 0; i < firstDow; i++) { %>
        <div class="bg-white p-1 min-h-[80px]"></div>
      <% } %>
      <% calendar.forEach(day => { %>
        <div class="bg-white p-1 min-h-[80px] <%= day.dow === 0 ? 'bg-red-50' : day.dow === 6 ? 'bg-blue-50' : '' %>">
          <div class="text-xs font-bold mb-1 <%= day.dow === 0 ? 'text-red-500' : day.dow === 6 ? 'text-blue-500' : 'text-gray-700' %>"><%= day.day %></div>
          <% day.shifts.forEach(s => { %>
            <div class="text-xs bg-indigo-100 text-indigo-700 rounded px-1 py-0.5 mb-0.5 truncate" title="<%= s.employee_name %>: <%= s.start_time %>-<%= s.end_time %>">
              <span class="font-medium"><%= s.employee_name %></span><br>
              <span class="text-indigo-500"><%= s.start_time %>-<%= s.end_time %></span>
              <form method="POST" action="/shifts/<%= s.id %>/delete" class="inline">
                <button type="submit" class="text-red-400 hover:text-red-600 ml-1" title="削除">&times;</button>
              </form>
            </div>
          <% }) %>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- シフト登録フォーム -->
  <div class="bg-white rounded-xl shadow p-5">
    <h2 class="font-bold text-gray-700 mb-4">シフト追加</h2>
    <% if (employees.length === 0) { %>
      <p class="text-gray-400 text-sm">先に従業員を登録してください</p>
    <% } else { %>
      <form method="POST" action="/shifts">
        <div class="space-y-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">従業員</label>
            <select name="employee_id" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
              <% employees.forEach(emp => { %>
                <option value="<%= emp.id %>"><%= emp.name %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">日付</label>
            <input type="date" name="date" required value="<%= year %>-<%= String(month).padStart(2, '0') %>-01"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
          </div>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">開始</label>
              <input type="time" name="start_time" required value="09:00"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">終了</label>
              <input type="time" name="end_time" required value="17:00"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">備考</label>
            <input type="text" name="note" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
          </div>
          <button type="submit" class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700 text-sm">追加</button>
        </div>
      </form>
    <% } %>
  </div>
</div>

<!-- シフト希望（承認待ち） -->
<% if (pendingRequests && pendingRequests.length > 0) { %>
<div class="mt-6 bg-white rounded-xl shadow p-5">
  <h2 class="font-bold text-gray-700 mb-4">
    シフト希望（承認待ち）
    <span class="bg-orange-500 text-white text-xs px-2 py-0.5 rounded-full ml-2"><%= pendingRequests.length %></span>
  </h2>
  <div class="space-y-3">
    <% pendingRequests.forEach(r => { %>
      <div class="border rounded-lg p-4 bg-yellow-50">
        <div class="flex flex-wrap justify-between items-start gap-2">
          <div>
            <span class="font-medium text-sm"><%= r.employee_name %></span>
            <span class="text-gray-500 text-sm ml-2"><%= r.date %></span>
            <span class="text-gray-500 text-sm ml-1"><%= r.start_time %> - <%= r.end_time %></span>
            <% if (r.note) { %><div class="text-xs text-gray-400 mt-1"><%= r.note %></div><% } %>
          </div>
          <div class="flex gap-2">
            <form method="POST" action="/shifts/requests/<%= r.id %>/approve" class="flex items-center gap-1">
              <input type="text" name="admin_note" placeholder="メモ" class="border rounded px-2 py-1 text-xs w-24">
              <button type="submit" class="bg-green-600 text-white px-3 py-1 rounded text-xs hover:bg-green-700">承認</button>
            </form>
            <form method="POST" action="/shifts/requests/<%= r.id %>/reject" class="flex items-center gap-1">
              <input type="text" name="admin_note" placeholder="理由" class="border rounded px-2 py-1 text-xs w-24">
              <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded text-xs hover:bg-red-600">却下</button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<% } %>

<%- include('../footer') %>
