<%- include('../layout') %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">お知らせ管理</h1>
</div>

<!-- 新規作成フォーム -->
<div class="bg-white rounded-xl shadow p-6 mb-6">
  <h2 class="text-lg font-semibold text-gray-700 mb-4">新しいお知らせを作成</h2>
  <form method="POST" action="/announcements">
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-600 mb-1">タイトル <span class="text-red-500">*</span></label>
      <input type="text" name="title" required
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
        placeholder="お知らせのタイトルを入力">
    </div>
    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-600 mb-1">内容</label>
      <textarea name="content" rows="4"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
        placeholder="お知らせの内容を入力"></textarea>
    </div>
    <button type="submit" class="bg-indigo-600 text-white px-5 py-2 rounded-lg text-sm hover:bg-indigo-700">投稿する</button>
  </form>
</div>

<!-- お知らせ一覧 -->
<div class="space-y-4">
  <% if (announcements.length === 0) { %>
    <div class="bg-white rounded-xl shadow p-8 text-center text-gray-400">
      お知らせはまだありません
    </div>
  <% } %>
  <% announcements.forEach(a => { %>
    <div class="bg-white rounded-xl shadow p-6">
      <!-- 表示モード -->
      <div id="view-<%= a.id %>">
        <div class="flex items-start justify-between">
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold text-gray-800 mb-1"><%= a.title %></h3>
            <p class="text-xs text-gray-400 mb-2">
              投稿: <%= a.created_at %>
              <% if (a.updated_at) { %><span class="ml-2">（編集済: <%= a.updated_at %>）</span><% } %>
            </p>
            <% if (a.content) { %>
              <p class="text-sm text-gray-600 whitespace-pre-wrap mb-3"><%= a.content %></p>
            <% } %>
            <!-- 既読状況 -->
            <% const readers = readMap[a.id] || []; %>
            <div class="flex items-center gap-2 flex-wrap mt-1">
              <span class="text-xs font-medium <%= readers.length > 0 && readers.length >= totalEmployees ? 'text-green-600' : 'text-orange-500' %>">
                👀 <%= readers.length %> / <%= totalEmployees %>人 確認済み
              </span>
              <% readers.forEach(r => { %>
                <span class="bg-green-100 text-green-700 text-xs px-1.5 py-0.5 rounded-full"><%= r.name %></span>
              <% }) %>
            </div>
          </div>
          <div class="ml-4 flex-shrink-0 flex gap-3">
            <button onclick="showEdit(<%= a.id %>)" class="text-indigo-500 hover:text-indigo-700 text-sm">編集</button>
            <form method="POST" action="/announcements/<%= a.id %>/delete"
              onsubmit="return confirm('このお知らせを削除しますか？')">
              <button type="submit" class="text-red-500 hover:text-red-700 text-sm">削除</button>
            </form>
          </div>
        </div>
      </div>
      <!-- 編集モード（初期非表示） -->
      <div id="edit-<%= a.id %>" style="display:none">
        <form method="POST" action="/announcements/<%= a.id %>/edit">
          <div class="mb-3">
            <label class="block text-sm font-medium text-gray-600 mb-1">タイトル</label>
            <input type="text" name="title" value="<%= a.title %>" required
              class="w-full border border-indigo-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500">
          </div>
          <div class="mb-3">
            <label class="block text-sm font-medium text-gray-600 mb-1">内容</label>
            <textarea name="content" rows="4"
              class="w-full border border-indigo-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500"><%= a.content || '' %></textarea>
          </div>
          <div class="flex gap-2">
            <button type="submit" class="bg-indigo-600 text-white px-4 py-1.5 rounded-lg text-sm hover:bg-indigo-700">保存</button>
            <button type="button" onclick="hideEdit(<%= a.id %>)" class="bg-gray-200 text-gray-700 px-4 py-1.5 rounded-lg text-sm hover:bg-gray-300">キャンセル</button>
          </div>
        </form>
      </div>
    </div>
  <% }) %>

<script>
function showEdit(id) {
  document.getElementById('view-' + id).style.display = 'none';
  document.getElementById('edit-' + id).style.display = 'block';
}
function hideEdit(id) {
  document.getElementById('edit-' + id).style.display = 'none';
  document.getElementById('view-' + id).style.display = 'block';
}
</script>
</div>

<%- include('../footer') %>
