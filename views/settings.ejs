<%- include('layout') %>

<h1 class="text-2xl font-bold text-gray-800 mb-6">設定</h1>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- 事業所情報 -->
  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="font-bold text-gray-700 mb-4">事業所情報</h2>
    <form method="POST" action="/settings">
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">事業所名称</label>
          <input type="text" name="business_name" value="<%= settings.business_name || '' %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">住所</label>
          <input type="text" name="address" value="<%= settings.address || '' %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">賃金締切日</label>
          <input type="text" name="closing_day" value="<%= settings.closing_day || '末日' %>" placeholder="例: 末日, 15日"
            class="w-full border border-gray-300 rounded-lg px-3 py-2">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">賃金支払日</label>
          <input type="text" name="pay_day" value="<%= settings.pay_day || '翌月25日' %>" placeholder="例: 翌月25日"
            class="w-full border border-gray-300 rounded-lg px-3 py-2">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">時間外割増率</label>
          <input type="number" step="0.01" name="overtime_rate" value="<%= settings.overtime_rate || '1.25' %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">深夜割増率</label>
          <input type="number" step="0.01" name="night_rate" value="<%= settings.night_rate || '1.25' %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2">
        </div>
        <button type="submit" class="bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700">保存</button>
      </div>
    </form>
  </div>

  <!-- パスワード変更 -->
  <div class="bg-white rounded-xl shadow p-6">
    <h2 class="font-bold text-gray-700 mb-4">パスワード変更</h2>
    <form method="POST" action="/settings/password">
      <div class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">現在のパスワード</label>
          <input type="password" name="current_password" required
            class="w-full border border-gray-300 rounded-lg px-3 py-2">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">新しいパスワード</label>
          <input type="password" name="new_password" required minlength="4"
            class="w-full border border-gray-300 rounded-lg px-3 py-2">
        </div>
        <button type="submit" class="bg-orange-500 text-white px-6 py-2 rounded-lg hover:bg-orange-600">変更</button>
      </div>
    </form>
  </div>
</div>

<%- include('footer') %>
